# monad-exporter — copy to .env or use in systemd Environment= / docker env.
# Empty values mean defaults from code are used.
# Load from file: go run ./cmd/monad-exporter --config .env   (environment variables override file values)

# HTTP address (Prometheus scrape). Alternative: only PORT=9100
# MONAD_EXPORTER_LISTEN=:9100
PORT=9101

# Node home directory (configs, .env with CHAIN/KEYSTORE_PASSWORD for keystore)
MONAD_HOME=/home/monad

# Local node metrics
METRICS_URL=http://127.0.0.1:8889/metrics

# Node JSON-RPC
RPC_URL=http://127.0.0.1:8080

# External RPC: network_name from node.toml is substituted into %s
EXTERNAL_RPC_TEMPLATE=https://rpc-%s.monadinfra.com

# HTTP request timeout (metrics, RPC)
# MONAD_EXPORTER_HTTP_TIMEOUT=15s

# monad-debug-node get-peers socket (default: $MONAD_HOME/monad-bft/controlpanel.sock)
# CONTROLPANEL_SOCK=

# MPT storage path for monad-mpt
MPT_STORAGE=/dev/triedb

# Port checked via ss (RPC listen)
RPC_LISTEN_PORT=8080

# Run monad-keystore once at startup to get Secp pubkey (1 = enabled). Password is in $MONAD_HOME/.env (KEYSTORE_PASSWORD)
# Alternative without keystore: MONAD_EXPORTER_SECP_PUBLIC_KEY=0x... (hex from monad-keystore / monad-status)
# MONAD_EXPORTER_ENABLE_KEYSTORE=0

# Monad staking (eth_call to precompile 0x...1000; see docs.monad.xyz/reference/staking/api)
# MONAD_EXPORTER_ENABLE_STAKING=0
# MONAD_STAKING_ADDRESS=0x0000000000000000000000000000000000001000
# VALIDATOR_ID=1
